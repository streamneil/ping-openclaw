# Openclaw Bearer Token（必填）
OPENCLAW_TOKEN=your_real_token_here

# Openclaw 底层引擎 WebSocket 地址（可选，默认 ws://127.0.0.1:18789）
# 与 openclaw 部署在同一台机器时保持 127.0.0.1 即可。
# OPENCLAW_WS_URL=ws://127.0.0.1:18789

# 本服务监听端口（可选，默认 8192）
# PORT=8192

# 监听地址（可选，默认 127.0.0.1 仅本机；改 0.0.0.0 开放给局域网）
# HOST=127.0.0.1

# 是否打印原始 WS 报文（排查 Openclaw 协议时设为 true）
# DEBUG_WS=false
